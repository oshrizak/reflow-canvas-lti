# =============================================================================
# Reflow Core API (upstream)
# =============================================================================
# Where the upstream Reflow Core API is reachable. The connector calls this
# for document submission, status polling, and PII approve/deny.
REFLOW_API_BASE_URL=http://localhost:8080
# API key the connector uses to authenticate to Reflow Core.
REFLOW_API_KEY=

# =============================================================================
# LTI 1.3
# =============================================================================
LTI_ENABLED=true
# Public URL where this connector is reachable from Canvas. Must be HTTPS in prod.
LTI_PUBLIC_URL=http://localhost:8000

# From the Canvas Developer Key:
LTI_ISSUER=https://canvas.instructure.com
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
LTI_AUTH_LOGIN_URL=https://canvas.instructure.com/api/lti/authorize_redirect
LTI_AUTH_TOKEN_URL=https://canvas.instructure.com/login/oauth2/token
LTI_JWKS_URL=https://canvas.instructure.com/api/lti/security/jwks

# OIDC state TTL (seconds) — protects against stale login redirects.
LTI_STATE_TTL_SECONDS=600

# RSA keypair this connector signs LTI JWTs with.
# Generate with scripts/generate_lti_keys.sh.
LTI_PRIVATE_KEY_PATH=/app/keys/lti_private.pem
LTI_PUBLIC_KEY_PATH=/app/keys/lti_public.pem

# =============================================================================
# Canvas API
# =============================================================================
CANVAS_API_URL=https://canvas.instructure.com

# Optional admin fallback token. Per-instructor OAuth tokens (below) are preferred.
CANVAS_API_TOKEN=

# Comma-separated Canvas course IDs the watcher will scan.
CANVAS_WATCHED_COURSES=

# How often (seconds) the watcher polls Canvas for new files.
CANVAS_POLL_SECONDS=300

# Origins allowed to embed the Panorama overlay (comma-separated).
CANVAS_ALLOWED_ORIGINS=https://canvas.instructure.com

# Per-instructor OAuth (Canvas Developer Key in OAuth-2 mode).
CANVAS_OAUTH_CLIENT_ID=
CANVAS_OAUTH_CLIENT_SECRET=

# =============================================================================
# Multi-tenant
# =============================================================================
# When true, the watcher uses per-instructor OAuth tokens stored in Redis
# instead of the single CANVAS_API_TOKEN above.
MULTI_TENANT_WATCHER=false

# =============================================================================
# Redis (Canvas-side state, eq-pdf:lti:* and eq-pdf:canvas:* keys)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Connector API keys (clients calling THIS service)
# =============================================================================
# Comma-separated allowlist of API keys accepted on protected endpoints.
API_KEYS=

# =============================================================================
# S3 (presigned URLs returned from Reflow Core)
# =============================================================================
# Public URL used in faculty-facing links.
S3_PUBLIC_URL=

# Internal URL the connector uses to FETCH results. Required when Reflow Core's
# presigned URLs point at a hostname the connector can't reach by that name —
# canvas/reflow_client.py rewrites the host before fetching.
#
# NOTE: the absence of this field is the bug that broke the bridge on 2026-06-17
# in the source fork. Keep it set whenever S3_PUBLIC_URL ≠ the host the connector
# can actually reach.
S3_INTERNAL_URL=

# =============================================================================
# AI / Translation (optional — Translate alt-format)
# =============================================================================
# When set, the Translate button in the alt-formats modal works. Calls
# Claude Sonnet 4.5 via the Anthropic Messages API. The translator prompt
# is explicitly told to preserve LaTeX math and mhchem chemistry markup
# verbatim, so equations don't get translated into the target language's
# prose.
# Leave empty to surface a clear 503 with setup instructions instead.
ANTHROPIC_API_KEY=

# =============================================================================
# AWS / Audio synthesis (optional — Audio MP3 alt-format)
# =============================================================================
# When set with valid credentials, the Audio (MP3) button in the
# alt-formats modal works. Calls Amazon Polly's neural TTS engine. The
# IAM user needs the ``polly:SynthesizeSpeech`` permission.
# Leave AWS_ACCESS_KEY_ID empty to surface a clear 503 with setup
# instructions instead.
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Publication gate (recommended for production)
# =============================================================================
# When true, the approve handler enforces:
#   * Zero ``error``-severity WCAG findings (or explicit waivers per
#     finding with a justification)
#   * Reviewer checklist items (headings, alt_text, tables,
#     reading_order) confirmed in the approval body
# When false (the default), the checks run but failures are advisory —
# faculty can publish a page with accessibility errors. Production
# deployments should ALWAYS set this to true.
REQUIRE_WCAG_GATE=false

# =============================================================================
# Data retention (recommended for production)
# =============================================================================
# How long the connector keeps each kind of record in Redis before the
# bridge worker's sweeper purges it (set to 0 to disable a sweep). The
# accessibility audit log is the legally sensitive piece — keep it as
# long as your institution's records-retention policy requires.
# Defaults: jobs 90 days, audit log 5 years.
CANVAS_JOB_RETENTION_SECONDS=7776000
CANVAS_AUDIT_RETENTION_SECONDS=157680000
